[Unit]
Description=Stephen Asatsa Website Backend API (Python)
After=network.target

[Service]
Type=simple
User=codecrafter
Group=codecrafter
WorkingDirectory=/home/codecrafter/combined/website/backend
Environment=PATH=/home/codecrafter/combined/website/backend/venv/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=/home/codecrafter/combined/website/backend/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/codecrafter/combined/website/backend/venv/bin/python server.py
Restart=always
RestartSec=10
StandardOutput=append:/home/codecrafter/combined/logs/backend.log
StandardError=append:/home/codecrafter/combined/logs/backend-error.log

[Install]
WantedBy=multi-user.target
