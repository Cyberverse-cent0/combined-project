# Shared Domain Configuration
# This file contains domain-related environment variables shared across both projects
# Local/Global Configuration - No domain name required

# Primary Domain Configuration
DOMAIN_NAME=localhost
SCHOLARS_SUBDOMAIN=scholars

# Full URLs
WEBSITE_URL=http://localhost:3000
SCHOLARS_URL=http://localhost:3000/scholars

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
ADMIN_ALLOWED_ORIGIN=http://localhost:3000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SCHOLARS_URL=""

# Admin Configuration
ADMIN_EMAIL=admin@localhost

# API Configuration
NEXT_PUBLIC_API_URL=""
ADMIN_BACKEND_URL=http://localhost:3000

# Base Path for Path-Based Routing (optional)
BASE_PATH=/scholars
