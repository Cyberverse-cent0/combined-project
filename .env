# Shared Domain Configuration
# This file contains domain-related environment variables shared across both projects

# Primary Domain Configuration
DOMAIN_NAME=http://192.168.0.101
SCHOLARS_SUBDOMAIN=scholars

# Full URLs
WEBSITE_URL=http://192.168.0.101
SCHOLARS_URL=http://192.168.0.101:4500

# CORS Configuration
CORS_ORIGIN=http://192.168.0.101
ADMIN_ALLOWED_ORIGIN=http://192.168.0.101

# NextAuth Configuration
NEXTAUTH_URL=http://192.168.0.101
NEXT_PUBLIC_SITE_URL=http://192.168.0.101
NEXT_PUBLIC_SCHOLARS_URL=http://192.168.0.101:4500

# Admin Configuration
ADMIN_EMAIL=admin@192.168.0.101

# API Configuration
NEXT_PUBLIC_API_URL=http://192.168.0.101
ADMIN_BACKEND_URL=http://192.168.0.101

# Base Path for Path-Based Routing (optional)
BASE_PATH=/scholars

